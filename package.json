      "@vue/compiler-ssr": "3.5.27",
      "@vue/shared": "3.5.27",
      "esbuild": "0.27.2",
      "globals": "17.0.0",
      "import-in-the-middle": "1.15.0",
      "unicorn-magic": "0.4.0",
      "vue": "3.5.27"
    },
    "ignoredBuiltDependencies": [
      "@contentstack/cli",
      "@contentstack/marketplace-sdk",
      "@parcel/watcher",
      "contentful-cli",
      "core-js",
      "es5-ext",
      "esbuild",
