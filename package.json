    "@scayle/storefront-nuxt": "8.59.3",
    "@scayle/storefront-product-detail": "1.8.0",
    "@scayle/storefront-product-listing": "2.4.0",
    "@scayle/storefront-promotions": "3.2.0",
    "@scayle/storefront-search": "0.4.0",
