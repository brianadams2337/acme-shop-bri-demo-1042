{
  "name": "@scayle/storefront-application-nuxt",
  "version": "1.16.0",
  "private": true,
  "description": "SCAYLE Storefront demo shop application based on Nuxt 3",
  "website": "https://scayle.dev/en/core-documentation/storefront-guide/storefront-application/readme/introduction",
  "bugs": {
    "url": "https://github.com/scayle/storefront-application/discussions"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": "^22.19.0 || ^24.0.0",
    "pnpm": ">= 10.16.1"
  },
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "cms:sync": "./scripts/sync-cms.sh",
    "dev:https": "nuxt dev --https",
    "dev": "nuxt dev --development",
    "e2e:test": "pnpm --dir ./testing/playwright e2e:test",
    "e2e:ui": "pnpm --dir ./testing/playwright e2e:ui",
    "artillery:load-test": "pnpm --dir ./testing/artillery artillery:load-test",
    "artillery:stress-test": "pnpm --dir ./testing/artillery artillery:stress-test",
    "format:fix": "prettier --ignore-unknown --log-level warn --write .",
    "format": "prettier --ignore-unknown --log-level warn --check .",
    "generate": "nuxt generate",
    "license:overview": "pnpx license-checker-rseidelsohn --csv --out node-licenses.csv",
    "lint:fix": "eslint . --fix",
    "lint": "pnpm eslint .",
    "prepare": "nuxt prepare",
    "preview": "nuxt preview",
    "test:ci": "vitest --run --coverage --reporter=default --reporter=junit --outputFile=./coverage/junit.xml",
    "test": "vitest",
    "typecheck": "nuxt typecheck",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o public/storybook"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@contentful/rich-text-types": "17.2.5",
    "@contentstack/cli": "1.55.1",
    "@eslint/eslintrc": "3.3.3",
    "@gtm-support/vue-gtm": "3.1.0",
    "@intlify/eslint-plugin-vue-i18n": "4.1.1",
    "@nuxt/eslint": "1.13.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/kit": "4.2.2",
    "@nuxt/schema": "4.2.2",
    "@nuxt/test-utils": "3.22.0",
    "@nuxtjs/i18n": "10.2.1",
    "@nuxtjs/storybook": "9.0.1",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@parcel/watcher": "2.5.6",
    "@scayle/changelog-formatter": "1.1.2",
    "@scayle/checkout-types": "2.1.73",
    "@scayle/eslint-auto-explicit-import": "0.2.1",
    "@scayle/eslint-config-storefront": "4.7.22",
    "@scayle/eslint-plugin-vue-composable": "0.2.3",
    "@scayle/prettier-config-storefront": "2.0.3",
    "@storybook-vue/nuxt": "9.0.1",
