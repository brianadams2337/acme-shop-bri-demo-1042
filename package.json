    "@vuelidate/core": "2.0.3",
    "@vuelidate/validators": "2.0.4",
    "@vueuse/components": "14.1.0",
    "@vueuse/core": "14.1.0",
    "@vueuse/gesture": "2.0.0",
    "@vueuse/integrations": "14.1.0",
    "@vueuse/nuxt": "14.1.0",
    "axios": "1.12.2",
    "cf-content-types-generator": "2.16.1",
    "color": "5.0.3",
    "consola": "3.4.2",
    "contentful": "11.10.2",
    "defu": "6.1.4",
    "dompurify": "3.3.1",
    "focus-trap": "7.8.0",
    "knitwork": "1.3.0",
    "nanoid": "5.1.6",
    "pathe": "2.0.3",
    "schema-dts": "1.1.5",
    "storyblok-js-client": "7.2.2",
    "tabbable": "6.4.0",
    "ufo": "1.6.3",
    "unstorage": "1.17.4",
    "vue": "3.5.27",
    "vue-slider-component": "4.1.0-beta.7"
  },
  "lint-staged": {
    "./**/*{.js,.mjs,.cjs,.ts,.vue}": [
      "prettier --ignore-unknown --write",
      "eslint --fix"
    ],
    "./**/*{.md,.json,.css}": "prettier --ignore-unknown --write"
  },
  "pnpm": {
    "overrides": {
      "@nuxt/kit": "4.2.2",
      "@nuxt/schema": "4.2.2",
      "@storybook/builder-vite": "9.1.17",
      "@storybook/vue3-vite": "9.1.17",
