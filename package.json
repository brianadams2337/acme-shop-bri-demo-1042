    "@testing-library/vue": "8.1.0",
    "@types/color": "4.2.0",
    "@types/google.maps": "3.58.1",
    "@types/node": "22.19.7",
    "@typescript-eslint/scope-manager": "8.54.0",
    "@typescript-eslint/utils": "8.54.0",
    "@upstash/redis": "1.36.1",
    "@vitest/coverage-v8": "4.0.18",
    "@vue/test-utils": "2.4.6",
    "@vue/typescript-plugin": "3.2.4",
    "autoprefixer": "10.4.23",
    "contentful-cli": "3.10.2",
    "eslint": "9.39.2",
    "eslint-formatter-gitlab": "7.0.1",
    "eslint-plugin-playwright": "2.5.1",
    "eslint-plugin-storybook": "10.2.0",
    "eslint-plugin-tailwindcss": "3.18.2",
    "eslint-plugin-vuejs-accessibility": "2.4.1",
    "fishery": "2.4.0",
    "happy-dom": "20.3.9",
    "jiti": "2.6.1",
    "lint-staged": "16.2.7",
    "nuxt": "4.2.2",
    "nuxt-svgo": "4.2.6",
    "ofetch": "1.5.1",
    "prettier": "3.6.2",
    "slugify": "1.6.6",
    "storyblok": "4.3.2",
    "storybook": "10.2.0",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "utility-types": "3.11.0",
    "vitest": "4.0.18",
    "vitest-environment-nuxt": "1.0.1",
    "vue-tsc": "3.2.4"
  },
  "dependencies": {
    "@contentful/live-preview": "4.9.1",
    "@contentful/rich-text-html-renderer": "17.1.6",
    "@contentstack/delivery-sdk": "4.11.0",
    "@contentstack/live-preview-utils": "4.2.0",
